{ Пример 3: Программа с намеренными синтаксическими ошибками
  для демонстрации диагностики }
program ErrorDemo;

var
  x, y: integer;
  z       { <-- ошибка: нет ':' и типа }

begin
  x := 10;
  y := 20
  { <-- ошибка: нет ';' между операторами }
  z := x +   { <-- ошибка: незавершённое выражение }
  writeln(x + y)
end.
